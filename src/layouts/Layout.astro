---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        background-color: #0b0f19;
        color: #f3f4f6;
      }
    </style>
  </head>
  <body class="min-h-screen font-sans selection:bg-teal-500 selection:text-white">
    <slot />
  </body>
</html>
